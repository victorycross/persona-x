{
  "name": "persona-x",
  "version": "0.1.0",
  "description": "Structured AI persona creation, validation, and panel runtime",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "persona-x": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "create": "tsx src/cli/index.ts create",
    "refine": "tsx src/cli/index.ts refine",
    "validate": "tsx src/cli/index.ts validate",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src/ tests/",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "persona",
    "ai",
    "panel",
    "orchestration",
    "structured-personas",
    "llm"
  ],
  "author": "Brightpath Technologies",
  "license": "UNLICENSED",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "inquirer": "^9.3.8",
    "yaml": "^2.8.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "eslint": "^9.39.4",
    "next": "^15.5.15",
    "prettier": "^3.8.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
